{
  "name": "aft-actors-script",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Vinjatovix",
  "description": "Frontend for AFT Actors Script",
  "homepage": "https://github.com/vinjatovix/aft-actors-script#readme",
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.9.2"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "check-dependencies": "madge --circular ./src",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "lint:fix": "eslint . --ext .ts --fix",
    "pre-commit": "lint-staged",
    "test": "rm -rf coverage; jest --coverage --detectOpenHandles",
    "test:watch": "jest --watchAll"
  },
  "lint-staged": {
    "{src,tests}/**/*.ts": [
      "prettier --write",
      "npm run lint:fix"
    ]
  },
  "config": {
    "commit-message-validator": {
      "pattern": "^\\[GH-[\\d]+\\]\\s.*$",
      "errorMessage": "Invalid commit message. Valid example: [GH-123] feat(api): add new feature"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinjatovix/aft-actors-script.git"
  },
  "bugs": {
    "url": "https://github.com/vinjatovix/aft-actors-script/issues"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.2.5",
    "@mui/icons-material": "^7.0.1",
    "@mui/material": "^7.0.1",
    "@reduxjs/toolkit": "^2.6.1",
    "date-fns": "^4.1.0",
    "jwt-decode": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@eslint/js": "^9.23.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.13",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.1",
    "babel-jest": "^29.7.0",
    "commit-message-validator": "^1.0.2",
    "dotenv": "^16.4.7",
    "eslint": "^9.23.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-react-x": "^1.38.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "15.5.0",
    "madge": "^8.0.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.28.0",
    "vite": "^6.2.3",
    "whatwg-fetch": "^3.6.20"
  }
}
